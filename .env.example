# Copy these values into Vercel Project Settings > Environment Variables.
# Do not commit real secret keys.

# Recommended stack: Supabase Auth + Postgres + Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
SUPABASE_STORAGE_BUCKET=knowledge-files

# Optional if you later use Vercel Blob for file uploads instead of Supabase Storage
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token
